# Paper Fetch Skill configuration
#
# Copy this file to ~/.config/paper-fetch/.env, or keep it elsewhere and set
# PAPER_FETCH_ENV_FILE=/path/to/.env. A repo-local .env is not auto-loaded.
# Blank values are treated as "not configured". Process environment variables
# override values loaded from env files.

PAPER_FETCH_SKILL_USER_AGENT="paper-fetch-skill/1.0"

# Runtime paths
# PAPER_FETCH_DOWNLOAD_DIR=""
# XDG_DATA_HOME=""

# Formula conversion
# Default runtime behavior prefers texmath and falls back to mathml-to-latex.
# Uncomment to force a specific backend:
# PAPER_FETCH_FORMULA_TOOLS_DIR=""
# MATHML_CONVERTER_BACKEND="texmath"
# TEXMATH_BIN=""
# MATHML_TO_LATEX_NODE_BIN="node"
# MATHML_TO_LATEX_SCRIPT=""
#
# Advanced mml2tex backend overrides. The default installer does not prepare
# these assets; set MATHML_CONVERTER_BACKEND="mml2tex" only when you provide
# the Java/XSLT toolchain yourself.
# MML2TEX_JAVA_BIN=""
# MML2TEX_CLASSPATH=""
# MML2TEX_SAXON_JAR=""
# MML2TEX_XMLRESOLVER_JAR=""
# MML2TEX_XMLRESOLVER_DATA_JAR=""
# MML2TEX_STYLESHEET=""
# MML2TEX_CATALOG=""

# Recommended for Crossref polite pool and contactability
CROSSREF_MAILTO=""

# Elsevier official APIs
ELSEVIER_API_KEY=""

# Wiley official TDM PDF lane
WILEY_TDM_CLIENT_TOKEN=""

# Wiley / Science / PNAS / AMS browser workflow
# PAPER_FETCH_BROWSER_USER_AGENT=""
# CLOAKBROWSER_HEADLESS="true"
# CLOAKBROWSER_BINARY_PATH=""
# CLOAKBROWSER_USER_DATA_DIR=""
# CLOAKBROWSER_TIMEOUT_MS="120000"
